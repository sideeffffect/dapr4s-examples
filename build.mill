package build

import mill.*
import mill.api.ModuleRef
import mill.scalalib.*
import mill.javalib.*
import coursier.maven.MavenRepository

private val NightliesRepo = MavenRepository(
  "https://repo.scala-lang.org/artifactory/maven-nightlies",
)

object nightliesJvmWorker extends JvmWorkerModule:
  override def repositoriesTask = Task.Anon {
    super.repositoriesTask() ++ Seq(NightliesRepo)
  }

val ScalaVersion = "3.9.0-RC1-bin-20260501-0c8c581-NIGHTLY"
val Dapr4sVersion = "0.8.0"

trait BaseModule extends ScalaModule:
  override def jvmWorker = ModuleRef(nightliesJvmWorker)
  def scalaVersion = ScalaVersion
  override def repositoriesTask = Task.Anon {
    super.repositoriesTask() ++ Seq(NightliesRepo)
  }

trait Dapr4sModule extends BaseModule:
  override def scalacOptions = Seq("-experimental")
  override def mvnDeps = Seq(
    mvn"com.github.sideeffffect::dapr4s:$Dapr4sVersion",
  )

trait PureModule extends Dapr4sModule:
  override def scalacOptions = super.scalacOptions() ++ Seq(
    "-language:experimental.safe",
  )

// ── Pure modules ──────────────────────────────────────────────────────────────
object `01-hello-state` extends PureModule
object `02-secrets-config` extends PureModule
object `03-hello-pubsub` extends PureModule
object `04-service-invocation` extends PureModule
object `05-distributed-lock` extends PureModule
object `06-actors` extends PureModule
object `07-workflows` extends PureModule

// Real-world case study: Grafana-style event-driven vulnerability scanner.
object `08-scan-gateway` extends PureModule
object `08-scan-worker` extends PureModule
object `08-scan-results` extends PureModule

// Real-world case study: ZEISS-style order fulfillment (saga across services).
object `09-order-service` extends PureModule
object `09-inventory-service` extends PureModule
object `09-payment-service` extends PureModule
object `09-shipping-service` extends PureModule

// Remaining building blocks: cryptography, jobs, conversation (LLM).
object `10-cryptography` extends PureModule
object `11-jobs` extends PureModule
object `12-conversation` extends PureModule

// Services files from multiple JARs must be merged (not last-wins) so that
// gRPC's ServiceLoader-based providers (DNS resolver, channel provider, etc.)
// are all registered. Mill's default rules don't do this, so we add it here.
trait ShellModule extends Dapr4sModule:
  override def mvnDeps = super.mvnDeps() ++ Seq(
    mvn"com.lihaoyi::upickle:3.3.1",
  )
  override def assemblyRules: Seq[Assembly.Rule] =
    super.assemblyRules ++ Seq(Assembly.Rule.AppendPattern("META-INF/services/.*"))

// ── Shell modules ─────────────────────────────────────────────────────────────
object `01-hello-state-shell` extends ShellModule:
  override def moduleDeps = Seq(`01-hello-state`)
object `02-secrets-config-shell` extends ShellModule:
  override def moduleDeps = Seq(`02-secrets-config`)
object `03-hello-pubsub-shell` extends ShellModule:
  override def moduleDeps = Seq(`03-hello-pubsub`)
object `04-service-invocation-shell` extends ShellModule:
  override def moduleDeps = Seq(`04-service-invocation`)
object `05-distributed-lock-shell` extends ShellModule:
  override def moduleDeps = Seq(`05-distributed-lock`)
object `06-actors-shell` extends ShellModule:
  override def moduleDeps = Seq(`06-actors`)
object `07-workflows-shell` extends ShellModule:
  override def moduleDeps = Seq(`07-workflows`)
object `08-scan-gateway-shell` extends ShellModule:
  override def moduleDeps = Seq(`08-scan-gateway`)
object `08-scan-worker-shell` extends ShellModule:
  override def moduleDeps = Seq(`08-scan-worker`)
object `08-scan-results-shell` extends ShellModule:
  override def moduleDeps = Seq(`08-scan-results`)
object `09-order-service-shell` extends ShellModule:
  override def moduleDeps = Seq(`09-order-service`)
object `09-inventory-service-shell` extends ShellModule:
  override def moduleDeps = Seq(`09-inventory-service`)
object `09-payment-service-shell` extends ShellModule:
