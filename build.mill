  override def moduleDeps = Seq(`11-jobs`)
object `12-conversation-shell` extends ShellModule:
  override def moduleDeps = Seq(`12-conversation`)

// ── Slides (Marp + Mermaid -> PDF) ──────────────────────────────────────────────
// Marp cannot render Mermaid natively, so this task pre-renders every ```mermaid
// fenced block in SLIDES.md to a PNG with the Mermaid CLI (mmdc), rewrites the deck
// to reference those images, then runs Marp (via npx) to produce the PDF.
//
// Requirements on PATH (or via env): mmdc, npx, and a Chromium/Chrome binary.
// Override the browser with CHROME_PATH if auto-detection fails.
//
//   ./mill slides          # build the PDF (lands at out/slides.dest/SLIDES.pdf)
//   ./mill show slides     # same, but also prints the PDF path as JSON
// ─────────────────────────────────────────────────────────────────────────────
def slidesSource = Task.Source("SLIDES.md")

def slides: T[PathRef] = Task {
  val src = slidesSource().path
  val work = Task.dest / "work"
  os.makeDir.all(work)

  def resolve(cmd: String): os.Path =
    val r = os.proc("which", cmd).call(check = false, stderr = os.Pipe)
    if r.exitCode == 0 then os.Path(r.out.trim())
    else Task.fail(s"`$cmd` not found on PATH")

  val chrome: os.Path =
    sys.env.get("CHROME_PATH").map(os.Path(_)).filter(os.exists).getOrElse {
      Seq(
        "/usr/bin/google-chrome-stable",
        "/usr/bin/google-chrome",
        "/usr/bin/chromium",
        "/usr/bin/chromium-browser",
        "/opt/google/chrome/chrome",
      ).map(os.Path(_)).find(os.exists)
        .getOrElse(Task.fail("No Chrome/Chromium found; set CHROME_PATH"))
    }
  val mmdc = resolve("mmdc")
  val npx = resolve("npx")

  os.write(
    work / "puppeteer.json",
    s"""{ "executablePath": "$chrome", "args": ["--no-sandbox"] }""",
  )

  // 1. Extract each ```mermaid block to its own .mmd and replace it in the deck
  //    with a Marp image reference (paths relative to the generated deck).
  val deck = List.newBuilder[String]
  val block = List.newBuilder[String]
  var n = 0
  var inBlock = false
  for line <- os.read.lines(src) do
    if !inBlock && line.trim == "```mermaid" then
      inBlock = true; n += 1; block.clear()
    else if inBlock && line.trim == "```" then
      inBlock = false
      os.write(work / s"diagram-$n.mmd", block.result().mkString("\n"))
      deck += s"![center](diagram-$n.svg)"
    else if inBlock then block += line
    else deck += line
  os.write(work / "deck.md", deck.result().mkString("\n"))

  // 2. Render every diagram to a crisp vector SVG. SVG stays sharp at any zoom
  //    in the PDF (no rasterisation blur); Chrome renders the mermaid foreignObject
  //    labels faithfully when Marp embeds the file.
  for i <- 1 to n do
    Task.log.info(s"rendering diagram-$i")
    os.proc(
      mmdc, "-p", work / "puppeteer.json",
      "-i", work / s"diagram-$i.mmd",
      "-o", work / s"diagram-$i.svg",
      "-b", "transparent",
    ).call(cwd = work, stdout = os.Inherit, stderr = os.Inherit)

  // 3. Marp -> PDF (allow local files so the PNGs are embedded).
  val pdf = Task.dest / "SLIDES.pdf"
  Task.log.info(s"running marp -> $pdf")
  os.proc(
    npx, "--yes", "@marp-team/marp-cli@latest",
    work / "deck.md", "--pdf", "--allow-local-files", "--no-stdin", "-o", pdf,
  ).call(
    cwd = work,
    env = Map("CHROME_PATH" -> chrome.toString),
    stdout = os.Inherit,
    stderr = os.Inherit,
  )

  PathRef(pdf)
}

// ── E2E test module ───────────────────────────────────────────────────────────
// Runs Dapr infrastructure via Docker Compose + Testcontainers (no dapr CLI
// required on the host). Assembly JARs are built as task dependencies and
// passed in via system properties so the test JVM can locate them.
// ─────────────────────────────────────────────────────────────────────────────
object e2e extends BaseModule with TestModule.Munit:
  override def scalacOptions = Seq("-experimental")
  override def mvnDeps = Seq(
    mvn"org.scalameta::munit:1.0.0",
    mvn"com.lihaoyi::os-lib:0.11.4",
    mvn"com.lihaoyi::upickle:4.1.0",
    mvn"org.testcontainers:testcontainers:1.21.4",
    mvn"org.slf4j:slf4j-simple:2.0.17",
  )
  // millSourcePath = {workspace}/e2e; one level up is the workspace root.
  private def workspaceRoot: os.Path = moduleDir / os.up
  override def forkEnv: T[Map[String, String]] = Task {
    super.forkEnv() ++ Map("DOCKER_HOST" -> "unix:///var/run/docker.sock")
  }
  override def forkArgs: T[Seq[String]] = Task {
    Seq(
      s"-De2e.projectRoot=${workspaceRoot}",
      s"-De2e.jar.hello-state=${`01-hello-state-shell`.assembly().path}",
      s"-De2e.jar.secrets-config=${`02-secrets-config-shell`.assembly().path}",
      s"-De2e.jar.hello-pubsub=${`03-hello-pubsub-shell`.assembly().path}",
      s"-De2e.jar.service-invocation=${`04-service-invocation-shell`.assembly().path}",
      s"-De2e.jar.distributed-lock=${`05-distributed-lock-shell`.assembly().path}",
      s"-De2e.jar.actors=${`06-actors-shell`.assembly().path}",
      s"-De2e.jar.workflows=${`07-workflows-shell`.assembly().path}",
      s"-De2e.jar.scan-gateway=${`08-scan-gateway-shell`.assembly().path}",
      s"-De2e.jar.scan-worker=${`08-scan-worker-shell`.assembly().path}",
      s"-De2e.jar.scan-results=${`08-scan-results-shell`.assembly().path}",
      s"-De2e.jar.order-service=${`09-order-service-shell`.assembly().path}",
      s"-De2e.jar.inventory-service=${`09-inventory-service-shell`.assembly().path}",
      s"-De2e.jar.payment-service=${`09-payment-service-shell`.assembly().path}",
      s"-De2e.jar.shipping-service=${`09-shipping-service-shell`.assembly().path}",
      s"-De2e.jar.cryptography=${`10-cryptography-shell`.assembly().path}",
      s"-De2e.jar.jobs=${`11-jobs-shell`.assembly().path}",
      s"-De2e.jar.conversation=${`12-conversation-shell`.assembly().path}",
    )
  }
