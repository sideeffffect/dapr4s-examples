package build

import mill.*
import mill.api.ModuleRef
import mill.scalalib.*
import mill.javalib.*
import coursier.maven.MavenRepository

private val NightliesRepo = MavenRepository(
  "https://repo.scala-lang.org/artifactory/maven-nightlies",
)

object nightliesJvmWorker extends JvmWorkerModule:
  override def repositoriesTask = Task.Anon {
    super.repositoriesTask() ++ Seq(NightliesRepo)
  }

val ScalaVersion = "3.9.0-RC1-bin-20260501-0c8c581-NIGHTLY"
val Dapr4sVersion = "0.12.0"

trait BaseModule extends ScalaModule:
  override def jvmWorker = ModuleRef(nightliesJvmWorker)
  def scalaVersion = ScalaVersion
  override def repositoriesTask = Task.Anon {
    super.repositoriesTask() ++ Seq(NightliesRepo)
  }

trait Dapr4sModule extends BaseModule:
  override def scalacOptions = Seq("-experimental")
  override def mvnDeps = Seq(
    mvn"com.github.sideeffffect::dapr4s:$Dapr4sVersion",
  )

trait PureModule extends Dapr4sModule:
  override def scalacOptions = super.scalacOptions() ++ Seq(
    "-language:experimental.safe",
  )

// ── Pure modules ──────────────────────────────────────────────────────────────
object `01-hello-state` extends PureModule
object `02-secrets-config` extends PureModule
object `03-hello-pubsub` extends PureModule
object `04-service-invocation` extends PureModule
object `05-distributed-lock` extends PureModule
object `06-actors` extends PureModule
object `07-workflows` extends PureModule

// Real-world case study: Grafana-style event-driven vulnerability scanner.
object `12-scan-gateway` extends PureModule
object `12-scan-worker` extends PureModule
object `12-scan-results` extends PureModule

// Real-world case study: ZEISS-style order fulfillment (saga across services).
object `13-order-service` extends PureModule
object `13-inventory-service` extends PureModule
object `13-payment-service` extends PureModule
object `13-shipping-service` extends PureModule

// Remaining building blocks: cryptography, jobs, conversation (LLM).
object `08-cryptography` extends PureModule
object `09-jobs` extends PureModule
object `10-conversation` extends PureModule
object `11-bindings` extends PureModule

// Observability & the Diagrid dashboard: a workflow that fans across service
// invocation + pub/sub, with traces/metrics/logs funnelled into SigNoz.
object `14-orders` extends PureModule
object `14-pricing` extends PureModule

// Services files from multiple JARs must be merged (not last-wins) so that
// gRPC's ServiceLoader-based providers (DNS resolver, channel provider, etc.)
// are all registered. Mill's default rules don't do this, so we add it here.
trait ShellModule extends Dapr4sModule:
  override def mvnDeps = super.mvnDeps() ++ Seq(
    mvn"com.lihaoyi::upickle:3.3.1",
  )
  override def assemblyRules: Seq[Assembly.Rule] =
    super.assemblyRules ++ Seq(Assembly.Rule.AppendPattern("META-INF/services/.*"))

